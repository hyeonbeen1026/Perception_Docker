# 도커 설치확인
# 도커 버전 확인 (설치 안 되어 있으면 command not found가 뜹니다)
docker --version

# 혹시 실행 중이거나 정지된 컨테이너가 있는지 확인
sudo docker ps -a

# 다운로드 되어 있는 이미지 확인
sudo docker images


# 도커서비스 삭제
# 1. 실행 중인 도커 서비스 중지
sudo systemctl stop docker

# 2. 도커 관련 패키지 모두 삭제
sudo apt-get purge -y docker-engine docker docker.io docker-ce docker-ce-cli docker-compose-plugin

# 3. 사용되지 않는 패키지 정리
sudo apt-get autoremove -y --purge

# 4. 도커 이미지, 컨테이너, 설정 파일이 저장된 핵심 폴더 삭제 (가장 중요!)
sudo rm -rf /var/lib/docker
sudo rm -rf /var/lib/containerd
sudo rm -rf /etc/docker


#도커 이미지 생성
# 현재 폴더(.)의 Dockerfile을 읽어서 'my_perception_env'라는 이름의 이미지를 만듦
docker build -t my_perception_env .


#도커 실행
# 가장 기본적인 실행 (컨테이너 내부 터미널로 접속)
docker run -it --name my_container my_perception_env

#실무용 실행 (볼륨 마운트 + GPU 사용)
# -v: 내 노트북의 폴더와 도커 안의 폴더를 연결 (코드 수정 시 바로 반영됨)
# --gpus all: PyTorch/YOLO가 그래픽카드를 쓸 수 있게 해줌 (nvidia-container-toolkit 설치 필요)
docker run -it --gpus all --name my_container -v ~/my_code:/root/workspace my_perception_env


#도커에서 나가기 
exit

#도커 다시실행
docker start perception_container
docker exec -it perception_container bash





#VS Code 도커 연동
1단계: 필수 확장 프로그램 설치

    내 노트북에서 VS Code를 엽니다.

    좌측 메뉴에서 확장(Extensions) 아이콘을 클릭하거나 단축키 Ctrl + Shift + X를 누릅니다.

    검색창에 Dev Containers를 검색합니다. (Microsoft에서 공식 지원하는 확장 프로그램입니다.)

    [Install (설치)] 버튼을 눌러 설치합니다.

2단계: 도커 컨테이너 실행 확인

VS Code를 연결하려면 컨테이너가 켜져 있어야 합니다. 기존에 열려있던 노트북 터미널에서 컨테이너가 잘 돌아가고 있는지 확인해 주세요.
(만약 꺼져있다면 docker start perception_container 명령어로 켜주시면 됩니다.)
3단계: VS Code를 컨테이너에 꽂아 넣기 (핵심!)

    VS Code 화면에서 단축키 F1 (또는 Ctrl + Shift + P)을 눌러 상단에 **명령 팔레트(Command Palette)**를 띄웁니다.

    검색창에 **Attach to Running Container**라고 타이핑한 뒤, 아래에 뜨는 **Dev Containers: Attach to Running Container...**를 클릭합니다.

    현재 내 컴퓨터에서 돌고 있는 도커 컨테이너 목록이 뜹니다. 여기서 우리가 만든 **perception_container**를 선택합니다.

    새로운 VS Code 창이 하나 더 열립니다. (처음 연결할 때는 도커 내부에 VS Code 서버를 설치하느라 1~2분 정도 소요될 수 있습니다.)

4단계: 작업 폴더 열기

    새로 열린 VS Code 창(컨테이너 내부와 연결된 창)에서 좌측의 [Open Folder (폴더 열기)] 버튼을 누릅니다.

    경로를 적는 칸이 나오면, 우리가 Dockerfile에서 지정했던 작업 공간인 **/root/workspace**를 입력하고 OK를 누릅니다.


